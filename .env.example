# REALITY OS — XAB Environment Variables
# Copy to .env.local for local development. Never commit real values.

# ========================
# CORE
# ========================
NEXT_PUBLIC_APP_URL=https://xab.yourdomain.com

# ========================
# SUPABASE
# ========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=                  # Transaction pooler URL (IPv4 compatible)

# ========================
# CRON SECURITY
# ========================
CRON_SECRET=                      # Long random string. Required on ALL /api/cron/* routes.

# ========================
# AI / LLM
# ========================
OPENAI_API_KEY=
OPENAI_ORG_ID=                    # Optional
EMBEDDING_MODEL=text-embedding-3-large   # Pending provider decision
LLM_MODEL=gpt-4o

# ========================
# MCP GATEWAY
# ========================
MCP_OAUTH_CLIENT_ID_BASE44=       # Issued after gateway is live
MCP_OAUTH_CLIENT_SECRET_BASE44=
MCP_OAUTH_CLIENT_ID_GPT=
MCP_OAUTH_CLIENT_SECRET_GPT=
MCP_JWT_SECRET=                   # For session signing

# ========================
# FINANCIAL INTELLIGENCE
# ========================
# Provider TBD — awaiting Jeremy decision
FINANCIAL_DATA_PROVIDER=          # e.g. polygon, factset, bloomberg
FINANCIAL_API_KEY=

# ========================
# SCRAPING
# ========================
SCRAPER_USER_AGENT=RealityOS-Scraper/1.0 (+https://xab.yourdomain.com/scraper-policy)
SCRAPER_MAX_BYTES_PER_DOMAIN=10485760    # 10MB default
BROWSER_TIMEOUT_MS=30000

# ========================
# OBSERVABILITY
# ========================
OTLP_ENDPOINT=                    # OpenTelemetry collector endpoint
OTLP_HEADERS=                     # Auth headers for OTLP

# ========================
# VERCEL
# ========================
# Set in Vercel dashboard, not .env
# VERCEL_URL is auto-set by Vercel
